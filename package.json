{
  "version": "0.1.0",
  "preview": false,
  "name": "csv-table-viewer-lite",
  "displayName": "CSV & Parquet Table Viewer Lite",
  "description": "Display CSV files as interactive tables inside VS Code.",
  "publisher": "psynowiec",
  "extensionKind": [
    "workspace"
  ],
  "author": {
    "name": "Piotr Synowiec",
    "email": "psynowiec@gmail.com"
  },
  "repository": "https://github.com/mysiar-org/vsc-ext-csv-table-viewer",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.63.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:csv-table-viewer.openCsvFromExplorer"
  ],
  "contributes": {
    "commands": [
      {
        "command": "csv-table-viewer.openCsvFromExplorer",
        "title": "Open CSV in Table Viewer",
        "category": "hidden"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "csv-table-viewer.openCsvFromExplorer",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "csv-table-viewer.openCsvFromExplorer",
          "when": "resourceExtname =~ /\\.csv/i",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/emscripten": "^1.41.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.63.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}