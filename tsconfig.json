{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"outDir": "out",
		"rootDir": "src",
		"lib": [
			"es2020",
			"dom"
		],
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"types": [
			"node",
			"emscripten"
		]
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}